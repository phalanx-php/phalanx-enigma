{
    "name": "phalanx/enigma",
    "description": "Non-blocking SSH command execution, file transfer, and tunnel management as Phalanx tasks",
    "type": "library",
    "license": "MIT",
    "homepage": "https://github.com/phalanx-php/phalanx-enigma",
    "authors": [
        {
            "name": "Jonathan Havens",
            "email": "mail@phalanx-php.com"
        }
    ],
    "require": {
        "php": "^8.4",
        "phalanx/aegis": "^0.5",
        "react/child-process": "^0.6",
        "react/async": "^4.3",
        "react/event-loop": "^1.5",
        "react/promise": "^3.2",
        "react/promise-timer": "^1.11"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Phalanx\\Enigma\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Phalanx\\Enigma\\Tests\\": "tests/"
        }
    }
}
